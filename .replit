modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Notha (WhatsApp Agent)"

[[workflows.workflow]]
name = "Notha (WhatsApp Agent)"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/notha && /home/runner/workspace/.pythonlibs/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["python_openai_ai_integrations:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8081

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]
